APP_NAME=Local Vocal Assistant
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=false
LOG_LEVEL=INFO

API_PREFIX=/api/v1

OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_REQUEST_TIMEOUT=180
OLLAMA_RETRY_ATTEMPTS=3
OLLAMA_RETRY_BASE_DELAY=0.5
OLLAMA_TEMPERATURE=0.2
OLLAMA_NUM_CTX=4096

# Example external APFS-mounted storage path
APP_STORAGE_PATH=/Volumes/localvocal-data/storage
SQLITE_PATH=sqlite/assistant.db
CHROMA_PATH=chroma
CHROMA_COLLECTION_NAME=conversation_memory

EMBEDDING_MODEL=nomic-embed-text
MEMORY_TOP_K=5
SHORT_TERM_MESSAGE_LIMIT=10
LLM_MAX_CONTEXT_MESSAGES=12

WHISPER_MODEL_SIZE=base
STT_DEVICE=cpu
STT_BEAM_SIZE=5
STT_TEMPERATURE=0.0
STT_VAD_FILTER=true
STT_VAD_MIN_SILENCE_MS=500
TTS_MODEL_NAME=tts_models/en/ljspeech/tacotron2-DDC
TTS_OUTPUT_DIR=audio

DUCKDUCKGO_REGION=wt-wt
DUCKDUCKGO_SAFESEARCH=moderate
DUCKDUCKGO_TIME_LIMIT=m
DUCKDUCKGO_MAX_RESULTS=5
DUCKDUCKGO_REQUEST_TIMEOUT=8.0
DUCKDUCKGO_RETRY_ATTEMPTS=2

UPLOAD_DIR=uploads
TEMP_DIR=tmp
