APP_NAME=Local Vocal Assistant
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=false
LOG_LEVEL=INFO

API_PREFIX=/api/v1

OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:8b
OLLAMA_REQUEST_TIMEOUT=180

SQLITE_PATH=storage/sqlite/assistant.db
CHROMA_PATH=storage/chroma
CHROMA_COLLECTION_NAME=conversation_memory

EMBEDDING_MODEL=nomic-embed-text
MEMORY_TOP_K=5
SHORT_TERM_MESSAGE_LIMIT=10
LLM_MAX_CONTEXT_MESSAGES=12

WHISPER_MODEL_SIZE=base
STT_DEVICE=cpu
TTS_MODEL_NAME=tts_models/en/ljspeech/tacotron2-DDC
TTS_OUTPUT_DIR=storage/audio

DUCKDUCKGO_REGION=wt-wt
DUCKDUCKGO_SAFESEARCH=moderate
DUCKDUCKGO_TIME_LIMIT=m
DUCKDUCKGO_MAX_RESULTS=5

UPLOAD_DIR=storage/uploads
TEMP_DIR=storage/tmp
